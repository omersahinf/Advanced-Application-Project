# Copy this file to .env before running `docker compose up`.

# Database (used by backend and chatbot)
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Backend / JWT (HS512 needs >=64 chars)
JWT_SECRET=change-me-please-use-at-least-64-characters-for-hs512-signing-key

# Google Gemini (chatbot + backend fallback)
AI_API_KEY=
LLM_MODEL=gemini-3-flash-preview

# Shared secret between backend and chatbot
CHATBOT_API_KEY=shared-secret-change-me

# Stripe test keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
