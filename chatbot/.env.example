OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Standalone mode (default): uses local SQLite with built-in seed data
DATABASE_URL=sqlite:///./ecommerce.db
# Shared DB mode: point to the same PostgreSQL as Spring Boot
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ecommerce_demo
# USE_SHARED_DB=true
# Internal API key for backend→chatbot communication (must match backend config)
CHATBOT_API_KEY=change-this-to-a-secure-random-key
